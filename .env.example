# =============================================================================
# a0-matrix Plugin Configuration
# Copy to .env and fill in your Matrix credentials
# =============================================================================

# ── Matrix Connection (REQUIRED) ──────────────────────────────────────────────
# Your Matrix homeserver URL
MATRIX_HOMESERVER_URL=https://localhost:8008

# Bot's full Matrix user ID
MATRIX_USER_ID=@agent:example.com

# Access token for the bot's Matrix account
# Generate via: curl -X POST https://matrix.example.com/_matrix/client/v3/login \
#   -H 'Content-Type: application/json' \
#   -d '{"type":"m.login.password","user":"agent","password":"secret"}'
MATRIX_ACCESS_TOKEN=your_access_token_here

# ── Matrix Session ────────────────────────────────────────────────────────────
MATRIX_DEVICE_ID=AgentZeroBot

# ── MCP Server (Outbound) ────────────────────────────────────────────────────
# Port for the MCP HTTP endpoint (default: 3000)
MCP_PORT=3000

# GHCR image version for matrix-mcp-server-r2
MCP_SERVER_VERSION=latest

# ── Agent Zero API (Bot → Agent Zero) ────────────────────────────────────────
# Agent Zero API endpoint (inside container: http://localhost:80/api_message)
A0_API_URL=http://localhost:80/api/api_message

# Agent Zero API key (leave empty if no auth configured)
A0_API_KEY=

# Agent Zero profile to use when bot forwards messages
A0_AGENT_PROFILE=

# ── Bot Behavior ──────────────────────────────────────────────────────────────
# Display name shown in Matrix rooms
BOT_DISPLAY_NAME=Agent Zero

# Identity string for system prompts
AGENT_IDENTITY=Agent Zero

# Sync long-poll timeout in milliseconds
SYNC_TIMEOUT_MS=30000

# Trigger prefix override (auto-generated from BOT_DISPLAY_NAME if empty)
# In group rooms, bot responds to @displayname: or @userid: mentions
# In DMs, bot responds to all messages
TRIGGER_PREFIX=

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info

# ── Instance Naming (for docker-compose) ──────────────────────────────────────
INSTANCE_NAME=a0
BOT_VERSION=latest
